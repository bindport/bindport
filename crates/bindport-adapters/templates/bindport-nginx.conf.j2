# Generated by BindPort. Edit the template, not this rendered file.
{% set listen = vars.listen | default("80") %}
{% if route.state == "active" and route.hostname %}
server {
	listen {{ listen }};
	server_name {{ route.hostname | tojson }};

	location / {
		proxy_pass {{ route.target_url | tojson }};
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
	}
}
{% elif route.state == "active" %}
# BindPort route {{ route.key }} is active but has no hostname, so no nginx server was rendered.
{% else %}
# BindPort route {{ route.key }} is {{ route.state }}, so no live nginx server was rendered.
{% endif %}
