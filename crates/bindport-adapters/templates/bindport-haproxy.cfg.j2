# Generated by BindPort. Edit the template, not this rendered file.
{% set bind = vars.bind | default(":80") %}
{% set frontend_name = vars.frontend_name | default("bindport_http") %}
frontend {{ frontend_name }}
	mode http
	bind {{ bind }}
{% for route in routes %}
{% if route.state == "active" and route.hostname %}
	acl host_{{ route.unique_slug }} hdr(host) -i {{ route.hostname | tojson }}
	use_backend backend_{{ route.unique_slug }} if host_{{ route.unique_slug }}
{% endif %}
{% endfor %}

{% for route in routes %}
{% if route.state == "active" and route.hostname %}
backend backend_{{ route.unique_slug }}
	mode http
	server {{ route.unique_slug }} {{ route.target_address | tojson }}
{% elif route.state == "active" %}
# BindPort route {{ route.key }} is active but has no hostname, so no HAProxy backend was rendered.
{% else %}
# BindPort route {{ route.key }} is {{ route.state }}, so no live HAProxy backend was rendered.
{% endif %}
{% endfor %}
