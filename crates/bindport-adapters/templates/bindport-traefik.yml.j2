# Generated by BindPort. Edit the template, not this rendered file.
{% set entrypoints = vars.entrypoints | default(["web"]) %}
{% set tls = vars.tls | default(false) %}
{% set middlewares = vars.middlewares | default([]) %}
{% if route.state == "active" and route.hostname %}
http:
  routers:
    {{ route.slug }}:
      rule: "Host(`{{ route.hostname }}`)"
      entryPoints:
{% for entrypoint in entrypoints %}
        - "{{ entrypoint }}"
{% endfor %}
      service: "{{ route.slug }}"
{% if tls %}
      tls: {}
{% endif %}
{% if middlewares %}
      middlewares:
{% for middleware in middlewares %}
        - "{{ middleware }}"
{% endfor %}
{% endif %}
  services:
    {{ route.slug }}:
      loadBalancer:
        servers:
          - url: "{{ route.target_url }}"
{% elif route.state == "active" %}
# BindPort route {{ route.key }} is active but has no hostname, so no router was rendered.
{% else %}
# BindPort route {{ route.key }} is {{ route.state }}, so no live router was rendered.
{% endif %}
